# Godot 4.x .gitignore
# Based on official Godot recommendations

# Godot-specific ignores
.import/
export.cfg
export_presets.cfg

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# Build outputs
/build/
/dist/

# OS-specific files
.DS_Store
Thumbs.db
*.tmp
*.swp
*.swo
*~

# IDE-specific files
.vscode/
.idea/
*.csproj.user
*.sln

# Logs
*.log

# User-specific files
*.user

# Temporary files
*.tmp
*.temp
